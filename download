// ── Bank Screen ──────────────────────────────────────────────────
function BankScreen({ history, flagged, onStartSession }) {
  const [search,   setSearch]   = useState("");
  const [selected, setSelected] = useState(new Set());
  const [filterPerf, setFilterPerf] = useState("all"); // all|new|wrong|correct|flagged

  const perfMap = useMemo(() => {
    const m = {};
    history.forEach(h => { m[h.id] = h.correct ? "correct" : "wrong"; });
    return m;
  }, [history]);

  const filtered = useMemo(() => QUESTIONS.filter(q => {
    if (search && !q.q.includes(search) && !q.topic.includes(search)) return false;
    if (filterPerf === "new"     && perfMap[q.id]) return false;
    if (filterPerf === "wrong"   && perfMap[q.id] !== "wrong") return false;
    if (filterPerf === "correct" && perfMap[q.id] !== "correct") return false;
    if (filterPerf === "flagged" && !flagged.has(q.id)) return false;
    return true;
  }), [search, filterPerf, perfMap, flagged]);

  const toggleSel = id => setSelected(p => {
    const n = new Set(p);
    n.has(id) ? n.delete(id) : n.add(id);
    return n;
  });
  const selectAll = () => setSelected(new Set(filtered.map(q=>q.id)));
  const clearAll  = () => setSelected(new Set());

  const startSelected = () => {
    const pool = QUESTIONS.filter(q=>selected.has(q.id)).sort(()=>Math.random()-.5);
    if (pool.length) onStartSession(pool);
  };

  const PERF_FILTERS = [
    {id:"all",     label:"הכל"},
    {id:"new",     label:"חדש"},
    {id:"wrong",   label:"שגוי"},
    {id:"correct", label:"נכון"},
    {id:"flagged", label:"⚑ מסומן"},
  ];

  return (
    <div className="page bank-page">
      <div className="hdr"><div className="hdr-lbl">שאלות</div><div className="hdr-title">מאגר</div></div>
      <input className="bank-search" placeholder="חיפוש בשאלות…" value={search} onChange={e=>setSearch(e.target.value)}/>

      {/* Perf filter chips */}
      <div className="bank-filters">
        {PERF_FILTERS.map(f=>(
          <button key={f.id} className={`bank-filter-chip ${filterPerf===f.id?"bank-fc-on":""}`}
            onClick={()=>setFilterPerf(f.id)}>{f.label}</button>
        ))}
      </div>

      {/* Selection bar */}
      {selected.size > 0 && (
        <div className="bank-sel-bar">
          <span>{selected.size} נבחרו</span>
          <button className="bank-sel-clear" onClick={clearAll}>נקה</button>
          <button className="bank-sel-start" onClick={startSelected}>התחל סשן ›</button>
        </div>
      )}

      {/* Select all row */}
      <div className="bank-sel-all-row">
        <span className="bank-count-lbl">{filtered.length} שאלות</span>
        <button className="bank-sel-all-btn" onClick={selected.size===filtered.length?clearAll:selectAll}>
          {selected.size===filtered.length?"בטל הכל":"בחר הכל"}
        </button>
      </div>

      <div className="bank-list">
        {filtered.slice(0,100).map(q=>{
          const p = perfMap[q.id];
          const isSel = selected.has(q.id);
          return (
            <div key={q.id} className={`bank-item ${isSel?"bank-item-sel":""}`} onClick={()=>toggleSel(q.id)}>
              <div className={`bank-checkbox ${isSel?"bank-cb-on":""}`}>{isSel?"✓":""}</div>
              <div className="bank-item-content">
                <div className="bank-item-id">{makeQid(q.source,q.id)}</div>
                <div className="bank-item-q">{q.q.slice(0,80)}{q.q.length>80?"…":""}</div>
              </div>
              <div className={`bank-item-dot ${p==="correct"?"bank-dot-c":p==="wrong"?"bank-dot-w":flagged.has(q.id)?"bank-dot-f":"bank-dot-u"}`}/>
            </div>
          );
        })}
      </div>
    </div>
  );
}

export default function App() {
  const [tab,      setTab]      = useState("home");
  const [screen,   setScreen]   = useState("loading"); // loading | splash | onboarding | app | quiz | results
  const [profile,  setProfile]  = useState(null);
  const [pool,     setPool]     = useState([]);
  const [history,  setHistory]  = useState([]);
  const [flagged,  setFlagged]  = useState(new Set());
  const [lastHist, setLastHist] = useState([]);
  const [ioModal,  setIoModal]  = useState(null);
  const [importMsg,setImportMsg]= useState(null);

  useEffect(() => {
    Promise.all([loadFromStorage(), loadProfile()]).then(([{ history, flagged }, profile]) => {
      setHistory(history);
      setFlagged(flagged);
      setProfile(profile);
      if (!profile) {
        setScreen("splash");
      } else {
        setScreen("app");
      }
    });
  }, []);

  const dismissSplash = useCallback(() => {
    if (screen === "splash") setScreen(profile ? "app" : "onboarding");
  }, [screen, profile]);

  const handleOnboardingDone = useCallback(prof => {
    setProfile(prof);
    setScreen("app");
  }, []);

  const handleStart = useCallback(pool => {
    setPool(pool);
    setScreen("quiz");
  }, []);

  const handleDailyStart = useCallback((poolOrMode) => {
    if (Array.isArray(poolOrMode)) {
      setPool(poolOrMode);
    } else {
      // fallback: build daily plan and combine all tasks
      const plan = buildDailyPlan(history, flagged, profile?.dailyTarget || 20);
      const combined = plan.flatMap(t=>t.pool).sort(()=>Math.random()-.5);
      setPool(combined.length ? combined : QUESTIONS.sort(()=>Math.random()-.5).slice(0,10));
    }
    setScreen("quiz");
  }, [history, flagged, profile]);

  const handleDone = useCallback(async hist => {
    const updated = [...history, ...hist];
    setHistory(updated);
    await saveHistory(updated);
    setLastHist(hist);
    setScreen("results");
  }, [history]);

  const handleSetFlagged = useCallback(async updater => {
    setFlagged(prev => {
      const next = updater(prev);
      saveFlagged(next);
      return next;
    });
  }, []);

  const handleReset = useCallback(async () => {
    if (!window.confirm("מחיקת כל הנתונים והגדרות הפרופיל. לא ניתן לשחזר. להמשיך?")) return;
