// ── Streaming fallback ────────────────────────────────────────────
async function streamExplanation(q, onChunk) {
  const letter = HEB[q.ans[0]], correct = q.opts[q.ans[0]];
  const sysPrompt = `You are a senior anesthesiology professor with complete mastery of Miller's Anesthesia.
Write explanations in Hebrew that include a direct verbatim quote from the book.
Format your response exactly like this:
[2-3 sentences in Hebrew explaining why the correct answer is correct and why the main distractor is wrong]

ציטוט ישיר מהספר (פרק X, עמ׳ Y):
"[exact English quote from Miller's Anesthesia, verbatim, 1-3 sentences]"`;
  const body = JSON.stringify({
    model:"claude-sonnet-4-20250514", max_tokens:700, stream:true,
    system: sysPrompt,
    messages:[{ role:"user", content:
      `שאלה מ-${q.source} (${BOOK_LABELS[q.book]||q.book}, ${q.pageRef}):\n${q.q}\nא.${q.opts[0]}\nב.${q.opts[1]}\nג.${q.opts[2]}\nד.${q.opts[3]}\nתשובה נכונה: ${letter}. ${correct}\n\nWrite the Hebrew explanation with a direct book quote as instructed.`
    }],
  });
  for (let i = 0; i < 4; i++) {
    if (i > 0) await sleep(2000 * i);
    const res = await fetch(API_URL, { method:"POST", headers:{"Content-Type":"application/json"}, body });
    if (res.status === 429) { if (i===3) throw new Error("המערכת עמוסה"); continue; }
    if (!res.ok) throw new Error("API " + res.status);
    const reader = res.body.getReader(), dec = new TextDecoder();
    while (true) {
      const { done, value } = await reader.read(); if (done) break;
      for (const line of dec.decode(value,{stream:true}).split("\n")) {
        if (!line.startsWith("data: ")) continue;
        const d = line.slice(6).trim(); if (d==="[DONE]") return;
        try { const p=JSON.parse(d); if(p.type==="content_block_delta"&&p.delta?.text) onChunk(p.delta.text); } catch {}
      }
    }
    return;
  }
}

