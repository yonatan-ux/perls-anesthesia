              </div>
            );
          })}
          {flaggedItems.map(h => {
            const qd = QUESTIONS.find(x=>x.id===h.id);
            return (
              <div key={h.id} className="rev-item rev-flag">
                <div className="rev-lbl rev-lbl-f">🚩 סומן לחזרה</div>
                <div>{qd?.q.slice(0,80)}{qd?.q.length>80?"…":""}</div>
              </div>
            );
          })}
        </div>
      </>}

      <div className="r-sec">פירוט שאלות</div>
      <div className="q-rows">
        {hist.map((h,i) => {
          const qd = QUESTIONS.find(x=>x.id===h.id);
          return (
            <div key={i} className="q-row">
              <span className="q-txt">{qd?.q}</span>
              <span className={`q-mark ${h.skipped?"msk":h.correct?"mok":"mno"}`}>
                {h.skipped?"↷":h.correct?"✓":"✗"}{flagged.has(h.id)?" 🚩":""}&nbsp;{qd?.id}
              </span>
            </div>
          );
        })}
      </div>
      <button className="btn-back" onClick={onBack}>← חזרה לבנאי החידון</button>
    </div>
  );
}

// ── Storage helpers ───────────────────────────────────────────────
const STOR_KEY_HIST    = "anesthesia:history:v1";
const STOR_KEY_FLAGS   = "anesthesia:flagged:v1";
const STOR_KEY_NOTES   = "anesthesia:notes:v1";
const STOR_KEY_PROFILE = "anesthesia:profile:v1";

// ── localStorage helpers (works on all browsers/devices) ───────────
function lsGet(key) {
  try { const v = localStorage.getItem(key); return v ? JSON.parse(v) : null; }
  catch { return null; }
}
function lsSet(key, value) {
  try { localStorage.setItem(key, JSON.stringify(value)); } catch {}
}
function lsDel(key) {
  try { localStorage.removeItem(key); } catch {}
}

// ── Profile helpers ─────────────────────────────────────────────────
async function loadProfile() {
  return lsGet(STOR_KEY_PROFILE);
}
async function saveProfile(profile) {
  lsSet(STOR_KEY_PROFILE, profile);
}

// ── Notes helpers ───────────────────────────────────────────────────
async function loadNotes() {
  return lsGet(STOR_KEY_NOTES) || {};
}
async function saveNote(qid, text) {
  const notes = lsGet(STOR_KEY_NOTES) || {};
  if (text.trim()) notes[qid] = text.trim();
  else delete notes[qid];
  lsSet(STOR_KEY_NOTES, notes);
}

// ── History helpers ─────────────────────────────────────────────────
async function loadFromStorage() {
  const history = lsGet(STOR_KEY_HIST) || [];
  const flaggedArr = lsGet(STOR_KEY_FLAGS) || [];
  return { history, flagged: new Set(flaggedArr) };
}
async function saveHistory(history) {
  lsSet(STOR_KEY_HIST, history);
}
async function saveFlagged(flagged) {
  lsSet(STOR_KEY_FLAGS, [...flagged]);
}

// ── Backup / Restore ────────────────────────────────────────────────
async function getBackupPayload() {
  const { history, flagged } = await loadFromStorage();
  const notes = lsGet(STOR_KEY_NOTES) || {};
  return JSON.stringify({ v:1, exportedAt: new Date().toISOString(),
    history, flagged:[...flagged], notes }, null, 2);
}
async function restoreFromJSON(text) {
  const payload = JSON.parse(text);
  if (!payload.v || !Array.isArray(payload.history)) throw new Error("קובץ לא תקין");
  lsSet(STOR_KEY_HIST,  payload.history);
  lsSet(STOR_KEY_FLAGS, payload.flagged || []);
  lsSet(STOR_KEY_NOTES, payload.notes   || {});
}

// ── Date helpers ───────────────────────────────────────────────────
function toDateStr(d) { return d.toISOString().slice(0,10); }
function today() { return toDateStr(new Date()); }
function daysUntil(dateStr) {
  const diff = new Date(dateStr) - new Date(today());
  return Math.max(0, Math.ceil(diff / 86400000));
}
function addDays(dateStr, n) {
  const d = new Date(dateStr); d.setDate(d.getDate() + n); return toDateStr(d);
}
// Count working days between today and examDate, excluding offDays (0=Sun,6=Sat) and holidays
function countWorkingDays(examDateStr, offDays, holidays) {
  let count = 0, cur = today();
  const offSet = new Set(offDays);
  const holSet = new Set(holidays || []);
  while (cur < examDateStr) {
    const dow = new Date(cur).getDay();
    if (!offSet.has(dow) && !holSet.has(cur)) count++;
    cur = addDays(cur, 1);
  }
  return count;
}

// ── QID generator ─────────────────────────────────────────────────
// Format: SHA-2405-001  (exam · year+month · question number)
function makeQid(source, questionNum) {
  const examMap = {
    "שלב א׳ · מאי 2024":      "SHA-2405",
    "בוחן אסותא":         "ASH-2505",
    "שלב א׳ · ספטמבר 2024":   "SHA-2409",
    "שלב ב׳ · מאי 2024":      "SHB-2405",
    "בילינסון · 2025":         "BLN-2501",
  };
  const code = examMap[source] || source.replace(/[^א-תa-zA-Z0-9]/g,"").slice(0,6).toUpperCase();
  return `${code}-${String(questionNum).padStart(3,"0")}`;
}

