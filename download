// ── Daily plan generator ─────────────────────────────────────────
// Returns 3 tasks with varying mix based on day-of-week rotation
function buildDailyPlan(history, flagged, dailyTarget) {
  const target = dailyTarget || 20;
  const perfMap = {};
  history.forEach(h => { perfMap[h.id] = h.correct ? "correct" : "wrong"; });

  const answered  = new Set(history.map(h=>h.id));
  const newQs     = QUESTIONS.filter(q=>!answered.has(q.id));
  const wrongQs   = QUESTIONS.filter(q=>perfMap[q.id]==="wrong");
  const flaggedQs = QUESTIONS.filter(q=>flagged.has(q.id));

  // Rotating split: varies by day of week to keep things fresh
  const dow = new Date().getDay(); // 0-6
  const splits = [
    [0.6, 0.3, 0.1], // Sun: mostly new
    [0.5, 0.4, 0.1], // Mon
    [0.4, 0.4, 0.2], // Tue: balanced
    [0.6, 0.3, 0.1], // Wed
    [0.3, 0.5, 0.2], // Thu: review heavy
    [0.5, 0.3, 0.2], // Fri
    [0.4, 0.4, 0.2], // Sat: balanced
  ];
  const [nFrac, wFrac, fFrac] = splits[dow];
  const nCount = Math.max(1, Math.round(target * nFrac));
  const wCount = Math.max(1, Math.round(target * wFrac));
  const fCount = Math.max(0, Math.round(target * fFrac));
  const minsPerQ = 1.5;

  return [
    {
      id: "new",
      label: "שאלות חדשות",
      count: Math.min(nCount, newQs.length),
      mins: Math.round(Math.min(nCount, newQs.length) * minsPerQ),
      icon: "✦",
      color: "var(--teal)",
      pool: newQs.sort(()=>Math.random()-.5).slice(0, nCount),
      available: newQs.length,
    },
    {
      id: "review",
      label: "חזרה על שגיאות",
      count: Math.min(wCount, wrongQs.length),
      mins: Math.round(Math.min(wCount, wrongQs.length) * minsPerQ),
      icon: "↺",
      color: "var(--red)",
      pool: wrongQs.sort(()=>Math.random()-.5).slice(0, wCount),
      available: wrongQs.length,
    },
    {
      id: "flagged",
      label: "שאלות מסומנות",
      count: Math.min(fCount, flaggedQs.length),
      mins: Math.round(Math.min(fCount, flaggedQs.length) * minsPerQ),
      icon: "⚑",
      color: "var(--gold)",
      pool: flaggedQs.sort(()=>Math.random()-.5).slice(0, fCount),
      available: flaggedQs.length,
    },
  ].filter(t => t.available > 0);
}

function HomeScreen({ profile, history, flagged, onStartSession }) {
  const daysLeft = profile ? daysUntil(profile.examDate) : 0;
  const examLabel = EXAM_OPTIONS.find(e=>e.id===profile?.examId)?.label || "בחינה";
  const totalQs = QUESTIONS.length;

  // Answered today
  const todayStr = today();
  const todayAnswered = history.filter(h => h.date?.startsWith(todayStr)).length;
  const dailyTarget = profile?.dailyTarget || 20;
  const dailyPct = Math.min(100, Math.round(todayAnswered/dailyTarget*100));

  // Stats
  const correct = history.filter(h=>h.correct).length;
  const total = history.length;
  const pct = total ? Math.round(correct/total*100) : 0;

  // Heatmap — last 70 days
  const heatData = useMemo(() => {
    const map = {};
    history.forEach(h => {
      const d = (h.date||"").slice(0,10);
      if (!map[d]) map[d] = 0;
      map[d]++;
    });
    // 28 days = 4 full weeks, aligned to Sunday start
    // pad so grid starts on Sunday
    const todayDate = today();
    const todayDow  = new Date(todayDate + 'T00:00:00').getDay(); // 0=Sun
    const totalDays = 28 + todayDow; // pad so last cell = today on correct column
    const days = [];
    for (let i=totalDays-1; i>=0; i--) {
      const d = addDays(todayDate, -i);
      const dt = new Date(d + 'T00:00:00');
      const dow = dt.getDay();
      days.push({
        date: d,
        count: map[d]||0,
        label: ['א','ב','ג','ד','ה','ו','ש'][dow],
        isToday: i === 0,
        isPadding: false,
        dayNum: dt.getDate(),
      });
    }
    return days;
  }, [history]);

  const maxHeat = Math.max(1, ...heatData.filter(d=>!d.isPadding).map(d=>d.count));

  // Streak
  const streak = useMemo(() => {
    let s=0, d=today();
    while(true) {
      const cnt = history.filter(h=>(h.date||"").startsWith(d)).length;
      if (cnt===0) break;
      s++; d=addDays(d,-1);
    }
    return s;
  }, [history]);

  // Weak topics
  const topicStats = useMemo(() => {
    const m = {};
    history.forEach(h => {
      const q = QUESTIONS.find(q=>q.id===h.id);
      if (!q) return;
      if (!m[q.topic]) m[q.topic] = {correct:0,total:0};
      m[q.topic].total++;
      if (h.correct) m[q.topic].correct++;
    });
    return Object.entries(m)
      .filter(([,v])=>v.total>=3)
      .map(([t,v])=>([t, Math.round(v.correct/v.total*100)]))
      .sort((a,b)=>a[1]-b[1])
      .slice(0,4);
  }, [history]);

  return (
    <div className="page home-page">
      {/* Countdown hero */}
      <div className="home-hero">
        <div className="home-days-sub">עד {examLabel}</div>
        <div className="home-days-num">{daysLeft}</div>
        <div className="home-days-label">ימים נותרו</div>
      </div>

      {/* Daily plan tasks */}
      {(() => {
        const tasks = buildDailyPlan(history, flagged, dailyTarget);
        const totalTodayTarget = tasks.reduce((s,t)=>s+t.count,0);
        const totalPct = totalTodayTarget ? Math.min(100,Math.round(todayAnswered/totalTodayTarget*100)) : 0;
        return (
          <div className="home-card daily-card">
            <div className="daily-header">
              <div>
                <div className="daily-title">תוכנית יומית</div>
                <div className="daily-sub">{todayAnswered} מתוך {totalTodayTarget} שאלות · {totalPct}%</div>
              </div>
              <div className="daily-date">{new Date().toLocaleDateString("he-IL",{weekday:"long",day:"numeric",month:"short"})}</div>
            </div>
            <div className="daily-bar-bg"><div className="daily-bar-fill" style={{width:`${totalPct}%`}}/></div>
            <div className="daily-tasks">
              {tasks.map(t => (
                <button key={t.id} className="daily-task" onClick={()=>onStartSession(t.pool)}
                  disabled={t.count===0}>
                  <span className="task-icon" style={{color:t.color}}>{t.icon}</span>
                  <span className="task-label">{t.label}</span>
                  <span className="task-meta">{t.count} שאלות · {t.mins} דק׳</span>
                  <span className="task-arrow">›</span>
                </button>
              ))}
            </div>
          </div>
        );
      })()}

      {/* Stats row */}
      <div className="home-stats-row">
        <div className="home-stat-box">
          <div className="home-stat-num">{total}</div>
          <div className="home-stat-lbl">שאלות</div>
        </div>
        <div className="home-stat-box">
          <div className="home-stat-num">{pct}%</div>
          <div className="home-stat-lbl">נכון</div>
        </div>
        <div className="home-stat-box">
          <div className="home-stat-num">{streak}</div>
          <div className="home-stat-lbl">רצף ימים 🔥</div>
        </div>
        <div className="home-stat-box">
          <div className="home-stat-num">{totalQs - total}</div>
          <div className="home-stat-lbl">נותרו</div>
        </div>
      </div>

      {/* 28-day cube grid */}
      <div className="home-card">
        <div className="home-card-title-row">
          <span className="home-card-title">4 שבועות אחרונים</span>
          <span className="home-card-title-sub">{heatData.filter(d=>d.count>0).length} ימי פעילות</span>
        </div>
        <div className="heat-dow-row">
          {['א','ב','ג','ד','ה','ו','ש'].map(d=><span key={d} className="heat-dow-lbl">{d}</span>)}
        </div>
        <div className="heat-grid">
          {heatData.map((d,i) => {
            const lvl = d.count===0 ? 0 : d.count>=20 ? 4 : d.count>=10 ? 3 : d.count>=4 ? 2 : 1;
            return (
              <div key={i}
                className={`heat-cube heat-${lvl}${d.isToday?" heat-today":""}`}
                title={`${d.date}: ${d.count} שאלות`}/>
            );
          })}
        </div>
        <div className="heat-legend-row">
          <span className="heat-leg-lbl">פחות</span>
          {[0,1,2,3,4].map(l=><div key={l} className={`heat-cube heat-${l}`}/>)}
          <span className="heat-leg-lbl">יותר</span>
        </div>
      </div>

      {/* Weak topics */}
      {topicStats.length>0 && (
        <div className="home-card">
          <div className="home-card-title">נושאים לחיזוק</div>
          {topicStats.map(([topic, pct]) => (
            <div key={topic} className="weak-row">
              <div className="weak-pct" style={{color: pct<50?"#b03020":pct<70?"#c4840a":"#1a7a70"}}>{pct}%</div>
              <div className="weak-info">
                <div className="weak-name">{topic.replace(/פרק \d+ — /,"")}</div>
                <div className="weak-bar-bg"><div className="weak-bar-fill" style={{width:`${pct}%`,background: pct<50?"#b03020":pct<70?"#c4840a":"#1a7a70"}}/></div>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  );
}

// ── Results Screen (Version A — עיתונאי) ─────────────────────────
function ResultsScreen({ hist, flagged, onBack }) {
  const total  = hist.length;
  const correct = hist.filter(h=>h.correct).length;
  const wrong   = hist.filter(h=>!h.correct&&!h.skipped).length;
  const skipped = hist.filter(h=>h.skipped).length;
  const pct    = total ? Math.round(correct/total*100) : 0;
  const mins   = Math.round(hist.reduce((s,h)=>s+(h.elapsed||0),0)/60);

  // By topic
  const byTopic = useMemo(() => {
    const m = {};
    hist.forEach(h => {
      const q = QUESTIONS.find(q=>q.id===h.id);
      if (!q) return;
      if (!m[q.topic]) m[q.topic] = {c:0,t:0};
      m[q.topic].t++;
      if (h.correct) m[q.topic].c++;
    });
    return Object.entries(m).map(([topic,v])=>([topic,Math.round(v.c/v.t*100),v.t,v.c]))
      .sort((a,b)=>a[1]-b[1]);
  }, [hist]);

  const dateStr = new Date().toLocaleDateString("he-IL",{weekday:"long",day:"numeric",month:"long",year:"numeric"});
  const sessionId = `SHA-${String(new Date().getMonth()+1).padStart(2,"0")}-${String(new Date().getDate()).padStart(2,"0")}-${String(Math.floor(Math.random()*900)+100)}`;

  return (
    <div className="page results-page">
      {/* Score hero */}
      <div className="res-hero">
        <div className="res-back-btn" onClick={onBack}>&#10005;</div>
        <div className="res-score">{pct}%</div>
        <div className="res-delta">{pct>=70?"✓ מעל הסף":"✗ מתחת לסף"}</div>
        <div className="res-meta">{dateStr} · {mins} דקות · {sessionId}</div>
      </div>

      {/* Stats row */}
      <div className="res-stats-row">
        <div className="res-stat"><span className="res-stat-num">{correct}</span><span className="res-stat-lbl">נכון</span></div>
        <div className="res-stat"><span className="res-stat-num res-wrong">{wrong}</span><span className="res-stat-lbl">שגוי</span></div>
        <div className="res-stat"><span className="res-stat-num">{skipped}</span><span className="res-stat-lbl">דילוג</span></div>
        <div className="res-stat"><span className="res-stat-num">{mins}</span><span className="res-stat-lbl">דקות</span></div>
      </div>

      {/* Insight */}
      {byTopic.length>0 && (
        <div className="res-insight">
          סשן חזק: את הטובים בקבוצה בנושא <strong>{byTopic[byTopic.length-1]?.[0]?.replace(/פרק \d+ — /,"")}</strong>
          {byTopic[0]?.[1] < 70 && <> — הנושא הראשון שתחזור נם עם ל <strong>{byTopic[0]?.[0]?.replace(/פרק \d+ — /,"")}</strong></>}.
        </div>
      )}

      {/* Topic breakdown */}
      <div className="res-topics">
        {byTopic.map(([topic,pct,total,correct],i) => (
          <div key={topic} className="res-topic-row">
            <div className="res-topic-rank">{String(i+1).padStart(2,"0")}</div>
            <div className="res-topic-info">
              <div className="res-topic-name">{topic.replace(/פרק \d+ — /,"")}</div>
              <div className="res-topic-source">{topic.match(/פרק \d+/)?.[0]} · שאלות {total}/{correct}</div>
            </div>
            <div className="res-topic-pct" style={{color:pct>=70?"#1a7a70":pct>=50?"#c4840a":"#b03020"}}>
              {pct}%
              <div className="res-topic-bar-bg"><div className="res-topic-bar" style={{width:`${pct}%`,background:pct>=70?"#1a7a70":pct>=50?"#c4840a":"#b03020"}}/></div>
            </div>
          </div>
        ))}
      </div>

      {/* Buttons */}
      <div className="res-btns">
        <button className="res-btn-p" onClick={onBack}>חזור לבית</button>
      </div>
    </div>
  );
}

