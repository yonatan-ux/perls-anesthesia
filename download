.sec{margin-bottom:24px}
.sec-lbl{font-family:'Space Mono',monospace;font-size:.65rem;letter-spacing:.13em;color:var(--soft);margin-bottom:10px;display:flex;align-items:center;gap:6px}
.sec-lbl::after{content:'';flex:1;height:1px;background:var(--rule)}
.chips{display:flex;flex-wrap:wrap;gap:7px}
.chip{padding:7px 13px;border-radius:20px;border:1.5px solid var(--rule);background:var(--paper);color:var(--soft);font-family:'Frank Ruhl Libre',Georgia,serif;font-size:.88rem;cursor:pointer;transition:all .15s;white-space:nowrap;line-height:1.2}
.chip:hover{border-color:var(--teal);color:var(--teal)}
.chip.on{background:var(--tl);border-color:var(--teal);color:var(--teal-d);font-weight:700}
.chip.on-red{background:var(--rl);border-color:var(--red);color:var(--red);font-weight:700}
.chip.on-gold{background:var(--gl);border-color:var(--gold);color:var(--gold);font-weight:700}
.chip.on-flag{background:var(--fl);border-color:var(--flag);color:var(--flag);font-weight:700}
.chip.pt-teal{background:var(--tl);border-color:#9accc4;color:var(--ink)}
.chip.pt-gold{background:var(--gl);border-color:#d4b860;color:var(--ink)}
.chip.pt-red{background:var(--rl);border-color:#d4a09a;color:var(--ink)}

/* count selector */
.count-row{display:flex;gap:7px;flex-wrap:wrap}
.count-chip{min-width:44px;text-align:center;padding:7px 10px;border-radius:8px;border:1.5px solid var(--rule);background:var(--paper);color:var(--soft);font-family:'Space Mono',monospace;font-size:.85rem;cursor:pointer;transition:all .15s}
.count-chip:hover{border-color:var(--teal);color:var(--teal)}
.count-chip.on{background:var(--ink);border-color:var(--ink);color:var(--paper);font-weight:700}
.count-chip:disabled{opacity:.35;cursor:default}

/* match counter */
.match-bar{background:#fff;border:1px solid var(--rule);border-radius:6px;padding:16px 18px;margin-bottom:20px;display:flex;align-items:center;justify-content:space-between;gap:12px}
.match-num{font-family:'Space Mono',monospace;font-size:2rem;font-weight:700;color:var(--teal);line-height:1}
.match-label{font-size:.82rem;color:var(--soft);line-height:1.5}
.match-none{color:var(--red)}

/* start button */
.btn-start{width:100%;padding:15px;background:var(--ink);color:var(--paper);border:none;border-radius:4px;font-family:'Frank Ruhl Libre',Georgia,serif;font-size:1.05rem;font-weight:700;cursor:pointer;transition:background .15s,transform .1s;letter-spacing:.02em}
.btn-start:hover:not(:disabled){background:#2a1e14;transform:translateY(-1px)}
.btn-start:disabled{opacity:.35;cursor:not-allowed;transform:none}

/* ─ progress bar ─ */
.pbar{height:2px;background:var(--rule);margin-bottom:28px;border-radius:2px;overflow:hidden}
.pfill{height:100%;background:var(--teal);border-radius:2px;transition:width .5s}

/* ─ question card ─ */
.qcard{background:#fff;border:1px solid var(--rule);border-radius:4px;padding:22px 20px;margin-bottom:20px;box-shadow:0 1px 4px rgba(0,0,0,.04)}
.qmeta{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px}
.badge{font-family:'Space Mono',monospace;font-size:.58rem;padding:3px 8px;border-radius:2px;letter-spacing:.05em;white-space:nowrap}
.bm{background:var(--gl);color:var(--gold);border:1px solid #d4b860}
.bt{background:var(--bl);color:var(--blue);border:1px solid #a0c0e8}
.bs{background:var(--p3);color:var(--soft);border:1px solid var(--rule)}
.qtext{font-size:1.08rem;line-height:1.75;font-weight:500;margin-bottom:2px}
.qimg{display:block;max-width:200px;margin:14px auto 4px;border:1px solid var(--rule);border-radius:4px}
.qimg-cap{text-align:center;font-size:.72rem;color:var(--faint);font-style:italic;margin-bottom:2px}

/* ─ options ─ */
.opts{display:flex;flex-direction:column;gap:10px;margin-bottom:12px}
.opt-wrap{display:flex;align-items:stretch}
.opt{flex:1;display:flex;align-items:flex-start;gap:12px;padding:13px 16px;background:#fff;border:1.5px solid var(--rule);border-radius:4px 0 0 4px;cursor:pointer;font-family:'Frank Ruhl Libre',Georgia,serif;font-size:.98rem;text-align:right;direction:rtl;line-height:1.55;color:var(--ink);transition:border-color .15s,background .15s;border-left:none}
.opt:hover:not(:disabled){border-color:var(--teal);background:var(--tl)}
.opt:disabled{cursor:default}
.oletter{flex-shrink:0;width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Space Mono',monospace;font-size:.72rem;font-weight:700;background:var(--p2);color:var(--soft);border:1.5px solid var(--rule);margin-top:1px;transition:all .15s}
.opttext{flex:1;unicode-bidi:plaintext}
.opt.struck .opttext{text-decoration:line-through;opacity:.5}
.opt.ok{border-color:var(--teal)!important;background:var(--tl)!important}
.opt.ok .oletter{background:var(--teal);border-color:var(--teal);color:#fff}
.opt.no{border-color:var(--red)!important;background:var(--rl)!important}
.opt.no .oletter{background:var(--red);border-color:var(--red);color:#fff}
.opt.dim{opacity:.4}
.strike-btn{width:32px;flex-shrink:0;display:flex;align-items:center;justify-content:center;background:var(--p2);border:1.5px solid var(--rule);border-right:none;border-radius:0 4px 4px 0;cursor:pointer;color:var(--faint);font-size:.8rem;transition:all .15s}
.strike-btn:hover{background:var(--p3);color:var(--ink)}
.strike-btn.on{background:#f0e8d8;color:var(--gold);border-color:#d4b860}
.hint{font-size:.68rem;color:var(--faint);text-align:center;margin-bottom:10px;font-family:'Space Mono',monospace;letter-spacing:.04em}
.skip-btn{width:100%;padding:10px;background:transparent;color:var(--soft);border:1.5px dashed var(--rule);border-radius:4px;font-family:'Frank Ruhl Libre',Georgia,serif;font-size:.9rem;cursor:pointer;transition:border-color .15s,color .15s;margin-bottom:16px}
.skip-btn:hover{border-color:var(--gold);color:var(--gold)}

/* ─ verdict + explanation ─ */
.verdict{padding:12px 16px;border-radius:4px;font-weight:700;font-size:.95rem;margin-bottom:14px;display:flex;align-items:center;gap:8px}
.vok{background:var(--tl);color:var(--teal);border:1px solid #9accc4}
.vno{background:var(--rl);color:var(--red);border:1px solid #d4a09a}
.vsk{background:var(--gl);color:var(--gold);border:1px solid #d4b860}
.exp{background:var(--p2);border:1px solid var(--rule);border-right:4px solid var(--teal);border-radius:4px;padding:16px 18px;margin-bottom:16px}
.exph{font-family:'Space Mono',monospace;font-size:.6rem;color:var(--teal);letter-spacing:.1em;margin-bottom:10px;display:flex;justify-content:space-between;align-items:center}
.expp{color:var(--gold);font-size:.6rem}
.pdf-page-badge{color:var(--teal);font-size:.85em;font-family:'Space Mono',monospace;font-weight:600;letter-spacing:.03em}
.perl-hdr{align-items:center;gap:12px}
.perl-brand{display:flex;align-items:center;gap:12px}
.perl-logo{width:52px;height:52px;border-radius:10px;object-fit:cover;flex-shrink:0}
.perl-app-name{font-size:1.15rem;font-weight:700;color:var(--ink);letter-spacing:.01em;font-family:'Space Mono',monospace}
.perl-subtitle{font-size:.62rem;color:var(--soft);letter-spacing:.03em;margin-top:2px}
.splash-screen{animation:fadeIn .6s ease}
..ob-headline-bold{font-size:1.4rem;font-weight:800;color:var(--ink);text-align:right;margin-bottom:3px;direction:rtl}
.ob-headline-sub{font-size:.85rem;color:var(--soft);text-align:right;margin-bottom:8px;direction:rtl}
.ob-q-count{font-size:.75rem;color:var(--gold);font-weight:600;text-align:right;margin-bottom:12px;direction:rtl}
.ob-disclaimer-box,.me-disclaimer-box{background:rgba(120,60,10,.06);border:1px solid rgba(120,60,10,.18);border-radius:8px;padding:10px 14px;margin-bottom:16px;font-size:.68rem;color:#6b3a0f;direction:rtl;text-align:right;line-height:1.55}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.splash-ded{max-width:380px;text-align:right}
.perl-dedication{background:rgba(154,112,32,.07);border:1px solid rgba(154,112,32,.18);border-radius:10px;padding:12px 16px;margin:0 0 4px;direction:rtl;text-align:right}
.perl-ded-name{font-size:.8rem;font-weight:600;color:var(--gold);font-family:'Space Mono',monospace;letter-spacing:.04em;margin-bottom:4px}
.perl-ded-text{font-size:.78rem;line-height:1.65;color:var(--soft)}
.exptxt{font-size:.93rem;line-height:1.78;direction:rtl}
.exp-structured{display:flex;flex-direction:column;gap:16px}
.dist-section{background:rgba(176,48,32,.06);border:1px solid rgba(176,48,32,.2);border-radius:8px;padding:14px 16px}
.dist-title{font-size:.65rem;font-family:'Space Mono',monospace;letter-spacing:.1em;color:var(--red);margin-bottom:10px;text-transform:uppercase}
.dist-item{display:flex;gap:10px;margin-bottom:8px;align-items:flex-start}
.dist-item:last-child{margin-bottom:0}
.dist-letter{font-family:'Space Mono',monospace;font-size:.75rem;font-weight:700;color:var(--red);background:rgba(176,48,32,.12);border-radius:4px;padding:2px 7px;min-width:24px;text-align:center;margin-top:2px;flex-shrink:0}
.dist-text{font-size:.88rem;line-height:1.65;color:var(--soft)}
.quotes-section{display:flex;flex-direction:column;gap:10px}
.quotes-title{font-size:.65rem;font-family:'Space Mono',monospace;letter-spacing:.1em;color:var(--gold);margin-bottom:4px;text-transform:uppercase}
.quote-card{background:var(--gl);border:1px solid rgba(154,112,32,.25);border-radius:8px;padding:13px 15px}
.quote-text{font-size:.87rem;line-height:1.7;color:var(--ink);font-style:italic;direction:ltr;text-align:left;margin-bottom:8px}
.hagev-btn{width:100%;background:none;border:1px solid var(--rule);border-radius:8px;padding:10px;cursor:pointer;color:var(--soft);font-size:.78rem;font-family:inherit;direction:rtl;transition:all .15s}
.hagev-btn:hover{border-color:var(--teal);color:var(--teal)}
.quote-source{font-size:.67rem;font-family:'Space Mono',monospace;color:var(--gold);text-align:left}
.exp-figure{margin:4px 0;border:1px solid var(--rule);border-radius:8px;overflow:hidden;background:white}
.exp-fig-img{width:100%;height:auto;display:block}
.exp-fig-caption{font-size:.76rem;color:var(--soft);padding:8px 12px;background:var(--p2);line-height:1.5;direction:rtl;text-align:right}
.expload{display:flex;align-items:center;gap:10px;color:var(--soft);font-size:.88rem;font-style:italic}
.experr{color:var(--red);font-size:.88rem;display:flex;flex-direction:column;gap:8px}
.retry-btn{align-self:flex-start;padding:5px 12px;background:var(--rl);color:var(--red);border:1px solid #d4a09a;border-radius:3px;font-family:'Frank Ruhl Libre',Georgia,serif;font-size:.82rem;cursor:pointer;font-weight:700}
.dots span{display:inline-block;width:5px;height:5px;border-radius:50%;background:var(--teal);margin:0 2px;animation:blink 1.2s ease infinite}
.dots span:nth-child(2){animation-delay:.2s}.dots span:nth-child(3){animation-delay:.4s}
.action-row{display:flex;gap:8px;margin-bottom:10px}
.btn-p{flex:1;padding:14px;background:var(--ink);color:var(--paper);border:none;border-radius:4px;font-family:'Frank Ruhl Libre',Georgia,serif;font-size:1rem;font-weight:700;cursor:pointer;transition:background .15s,transform .1s}
.btn-p:hover{background:#2a1e14;transform:translateY(-1px)}
.flag-btn{width:48px;flex-shrink:0;padding:0;background:#fff;border:1.5px solid var(--rule);border-radius:4px;cursor:pointer;font-size:1.1rem;transition:all .15s;display:flex;align-items:center;justify-content:center}
.flag-btn:hover{border-color:var(--flag);background:var(--fl)}
.flag-btn.on{border-color:var(--flag);background:var(--fl)}

/* ─ export / import ─ */
.io-btn{padding:5px 11px;border-radius:4px;background:var(--p2);border:1px solid var(--rule);color:var(--soft);font-family:'Space Mono',monospace;font-size:.62rem;cursor:pointer;transition:all .15s;white-space:nowrap;letter-spacing:.04em;display:inline-block}
.io-btn:hover{border-color:var(--teal);color:var(--teal)}
.io-import{cursor:pointer}
.io-msg{padding:10px 14px;border-radius:4px;font-size:.82rem;margin-bottom:16px;font-family:'Space Mono',monospace;font-size:.72rem}
.io-msg-ok{background:var(--tl);color:var(--teal);border:1px solid #9accc4}
.io-msg-err{background:var(--rl);color:var(--red);border:1px solid #d4a09a}
.modal-bg{position:fixed;inset:0;background:rgba(4,8,20,.85);z-index:200;display:flex;align-items:center;justify-content:center;padding:20px}
.modal-box{background:#fff;border-radius:8px;padding:24px 20px;width:100%;max-width:480px;display:flex;flex-direction:column;gap:12px;max-height:80vh;overflow-y:auto}
.modal-title{font-size:1.1rem;font-weight:900;color:var(--ink)}
.modal-sub{font-size:.82rem;color:var(--soft);line-height:1.5}
.modal-ta{width:100%;padding:10px 12px;background:var(--p2);border:1px solid var(--rule);border-radius:4px;font-family:'Space Mono',monospace;font-size:.7rem;direction:ltr;resize:vertical;min-height:160px;outline:none;color:var(--ink)}
.modal-ta:focus{border-color:var(--teal)}
.modal-btn-p{padding:11px;background:var(--ink);color:var(--paper);border:none;border-radius:4px;font-family:'Frank Ruhl Libre',Georgia,serif;font-size:.95rem;font-weight:700;cursor:pointer;transition:background .15s}
.modal-btn-p:hover:not(:disabled){background:#2a1e14}
.modal-btn-p:disabled{opacity:.4;cursor:not-allowed}
.modal-btn-s{padding:9px;background:transparent;color:var(--soft);border:1px solid var(--rule);border-radius:4px;font-family:'Frank Ruhl Libre',Georgia,serif;font-size:.9rem;cursor:pointer}
.modal-btn-s:hover{border-color:var(--soft)}


.note-box{margin-top:12px;border-top:1px solid var(--rule);padding-top:12px}
.note-toggle{background:none;border:none;font-family:'Frank Ruhl Libre',Georgia,serif;font-size:.82rem;color:var(--soft);cursor:pointer;padding:0;display:flex;align-items:center;gap:6px;transition:color .15s}
.note-toggle:hover{color:var(--ink)}
.note-ta{width:100%;margin-top:10px;padding:10px 12px;background:var(--gl);border:1px solid #d4b860;border-radius:4px;font-family:'Frank Ruhl Libre',Georgia,serif;font-size:.88rem;direction:rtl;color:var(--ink);resize:vertical;min-height:64px;outline:none;transition:border-color .15s;line-height:1.6}
.note-ta:focus{border-color:var(--gold)}
.note-ta::placeholder{color:#b8982a;opacity:.7}
.note-saved{font-size:.68rem;color:var(--gold);font-family:'Space Mono',monospace;margin-top:4px;height:14px;transition:opacity .3s}
.note-dot{display:inline-block;width:7px;height:7px;border-radius:50%;background:var(--gold);border:1px solid #d4b860;flex-shrink:0}


.res-rule{height:2px;background:var(--ink);margin-bottom:28px}
.res-lbl{font-family:'Space Mono',monospace;font-size:.62rem;letter-spacing:.14em;color:var(--soft);margin-bottom:10px}
.res-pct{font-size:clamp(4rem,18vw,6rem);font-weight:900;line-height:1;color:var(--teal);margin-bottom:6px}
.res-sub{font-size:.95rem;color:var(--soft);margin-bottom:28px}
.r-sec{font-family:'Space Mono',monospace;font-size:.62rem;letter-spacing:.12em;color:var(--soft);margin-bottom:12px;padding-bottom:6px;border-bottom:1px solid var(--rule)}
.topic-rows{display:flex;flex-direction:column;gap:8px;margin-bottom:24px}
.topic-row{display:flex;flex-direction:column;gap:4px}
.topic-hdr{display:flex;justify-content:space-between;font-size:.88rem}
.topic-name{color:var(--ink);font-weight:500}
.topic-pct{font-family:'Space Mono',monospace;font-size:.8rem;color:var(--soft)}
.tbar{height:4px;background:var(--p3);border-radius:2px;overflow:hidden}
.tbar-fill{height:100%;border-radius:2px;transition:width .6s}
.rev-list{display:flex;flex-direction:column;gap:8px;margin-bottom:24px}
.rev-item{padding:10px 14px;border-radius:4px;font-size:.88rem;line-height:1.5}
.rev-wrong{background:var(--rl);border:1px solid #d4a09a}
.rev-flag{background:var(--fl);border:1px solid #e0b890}
.rev-lbl{font-family:'Space Mono',monospace;font-size:.6rem;letter-spacing:.06em;margin-bottom:4px}
.rev-lbl-w{color:var(--red)}.rev-lbl-f{color:var(--flag)}
.q-rows{display:flex;flex-direction:column;margin-bottom:24px}
.q-row{display:flex;justify-content:space-between;align-items:baseline;padding:8px 0;border-bottom:1px solid var(--rule);gap:8px}
.q-txt{color:var(--soft);font-size:.82rem;flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.q-mark{font-family:'Space Mono',monospace;font-weight:700;font-size:.82rem;flex-shrink:0}
.mok{color:var(--teal)}.mno{color:var(--red)}.msk{color:var(--gold)}
.btn-back{width:100%;padding:14px;background:var(--ink);color:var(--paper);border:none;border-radius:4px;font-family:'Frank Ruhl Libre',Georgia,serif;font-size:1rem;font-weight:700;cursor:pointer;margin-top:4px}
.btn-back:hover{background:#2a1e14}

@keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}
.fi{animation:fadeIn .3s ease forwards}

.builder-shell{display:flex;flex-direction:column;height:100dvh;max-width:480px;margin:0 auto;background:var(--paper);overflow:hidden}
.builder-shell .hdr{margin-bottom:16px;padding:16px 20px 12px;border-bottom:2px solid var(--ink)}
.builder-shell .page-body{flex:1;overflow-y:auto;padding:16px 20px 20px;-webkit-overflow-scrolling:touch}

/* ─ builder redesign ─ */
.builder-cockpit{background:var(--ink);border-radius:8px;padding:16px 18px;margin-bottom:20px;display:flex;align-items:center;gap:16px}
.cockpit-donut{flex-shrink:0;position:relative;display:flex;align-items:center;justify-content:center}
.cockpit-center{position:absolute;text-align:center;pointer-events:none}
.cockpit-num{font-family:'Space Mono',monospace;font-size:.95rem;font-weight:700;color:#fff;line-height:1}
.cockpit-lbl{font-size:.52rem;color:rgba(255,255,255,.5)}
.cockpit-legend{display:flex;flex-direction:column;gap:5px;flex:1}
.cockpit-perf{display:flex;flex-direction:column;gap:5px;flex:1}
.cockpit-pf{display:flex;align-items:center;gap:7px;padding:5px 8px;border-radius:5px;cursor:pointer;border:1px solid transparent;transition:all .15s;background:rgba(255,255,255,.06)}
.cockpit-pf:hover{background:rgba(255,255,255,.12)}
.cockpit-pf.cpf-on{border-color:rgba(255,255,255,.35);background:rgba(255,255,255,.14)}
.cockpit-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.cockpit-row-lbl{font-size:.75rem;color:rgba(255,255,255,.7);flex:1}
.cockpit-row-num{font-family:'Space Mono',monospace;font-size:.75rem;color:#fff;font-weight:700}
.cockpit-row-pct{font-family:'Space Mono',monospace;font-size:.65rem;color:rgba(255,255,255,.45);min-width:28px;text-align:left}
.cockpit-start{display:flex;flex-direction:column;align-items:center;gap:4px;flex-shrink:0}
.cockpit-btn{background:var(--teal);color:#fff;border:none;border-radius:6px;padding:10px 14px;font-family:'Frank Ruhl Libre',Georgia,serif;font-size:1.05rem;font-weight:700;cursor:pointer;transition:background .15s,transform .1s;min-width:90px;text-align:center;line-height:1.3}
.cockpit-btn:hover:not(:disabled){background:#0f5248;transform:translateY(-1px)}
.cockpit-btn:disabled{opacity:.35;cursor:not-allowed;transform:none}
.cockpit-count{display:flex;gap:4px;flex-wrap:wrap;justify-content:center}
.cockpit-cc{min-width:32px;text-align:center;padding:4px 6px;border-radius:5px;border:1px solid rgba(255,255,255,.2);background:transparent;color:rgba(255,255,255,.6);font-family:'Space Mono',monospace;font-size:.72rem;cursor:pointer;transition:all .15s}
.cockpit-cc:hover{border-color:var(--teal);color:#fff}
.cockpit-cc.on{background:var(--teal);border-color:var(--teal);color:#fff;font-weight:700}
.cockpit-cc:disabled{opacity:.3;cursor:default}

/* collapsible accordion */
.acc-sec{margin-bottom:12px;border:1px solid var(--rule);border-radius:6px;overflow:hidden}
.acc-hdr{display:flex;align-items:center;justify-content:space-between;padding:10px 14px;cursor:pointer;background:#fff;transition:background .12s;user-select:none}
.acc-hdr:hover{background:var(--p2)}
.acc-hdr-left{display:flex;align-items:center;gap:8px}
.acc-lbl{font-family:'Space Mono',monospace;font-size:.65rem;letter-spacing:.12em;color:var(--soft)}
.acc-badge{background:var(--teal);color:#fff;border-radius:10px;padding:1px 7px;font-family:'Space Mono',monospace;font-size:.6rem;font-weight:700}
.acc-badge-warn{background:var(--flag)}
.acc-arrow{font-size:.7rem;color:var(--faint);transition:transform .2s}
.acc-arrow.open{transform:rotate(180deg)}
.acc-body{padding:12px 14px;background:var(--paper);border-top:1px solid var(--rule)}

/* topic search */
.topic-search{width:100%;padding:7px 10px;border:1px solid var(--rule);border-radius:4px;font-family:'Frank Ruhl Libre',Georgia,serif;font-size:.85rem;direction:rtl;background:#fff;color:var(--ink);margin-bottom:10px;outline:none;transition:border-color .15s}
.topic-search:focus{border-color:var(--teal)}
.topic-search::placeholder{color:var(--faint)}

