  // ── Results ────────────────────────────────────────────────────
  if (screen === "results") return (
    <><style dangerouslySetInnerHTML={{__html:CSS}}/><ResultsScreen hist={lastHist} flagged={flagged} onBack={()=>setScreen("app")}/></>
  );

  // ── Main app shell with bottom nav ────────────────────────────
  const handleNav = (t) => { setTab(t); };

  return (
    <>
      <style dangerouslySetInnerHTML={{__html:CSS}}/>
      {tab === "train" ? (
        <Builder history={history} flagged={flagged} onStart={handleStart}
          onExport={handleExport} onImport={handleOpenImport} importMsg={importMsg} onNav={handleNav}/>
      ) : (
      <div className="app-shell">
        <div className="app-content">
          {tab === "home"  && <HomeScreen  profile={profile} history={history} flagged={flagged} onStartSession={handleDailyStart}/>}
          {tab === "stats" && <StatsScreen history={history}/>}
          {tab === "bank"  && <BankScreen  history={history} flagged={flagged} onStartSession={(pool)=>{ setPool(pool); setScreen("quiz"); }}/>}
          {tab === "me"    && <MeScreen    profile={profile} onUpdateProfile={p=>{setProfile(p);}} onExport={handleExport} onImport={handleOpenImport} importMsg={importMsg} onReset={handleReset}/>}
        </div>
        <div className="bottom-disclaimer">פרל היא כלי עזר ואינה נועדה לשימוש קליני.</div>
        <BottomNav active={tab} onNav={handleNav}/>
      </div>
      )}

      {/* IO Modal */}
      {ioModal && (
        <div className="modal-bg" onClick={()=>setIoModal(null)}>
          <div className="modal-box" onClick={e=>e.stopPropagation()}>
            {ioModal.mode==="export" ? (
              <>
                <div className="modal-title">גיבוי נתונים</div>
                <div className="modal-sub">העתק את הטקסט ושמור אותו בצד.</div>
                <textarea className="modal-ta" readOnly value={ioModal.text} onFocus={e=>e.target.select()}/>
                <button className="modal-btn-p" onClick={async()=>{
                  try { await navigator.clipboard.writeText(ioModal.text); setIoModal(p=>({...p,copied:true})); setTimeout(()=>setIoModal(p=>p?({...p,copied:false}):null),2000); } catch {}
                }}>{ioModal.copied?"✓ הועתק!":"העתק ללוח"}</button>
                <button className="modal-btn-s" onClick={()=>setIoModal(null)}>סגור</button>
              </>
            ) : (
              <>
                <div className="modal-title">שחזור נתונים</div>
                <div className="modal-sub">הדבק כאן את טקסט הגיבוי שלך.</div>
                <IoImportBox onRestore={handleImport}/>
                <button className="modal-btn-s" onClick={()=>setIoModal(null)}>ביטול</button>
              </>
            )}
          </div>
        </div>
      )}
    </>
  );
}
