// ── PDF Page Offset Interpolation ────────────────────────────────
// Calibration points per book: [bookPage, pdfPage]
const PDF_CALIBRATION = {
  miller9: [
    [45,   50],
    [178,  200],
    [428,  500],
    [763,  900],
    [1191, 1400],
    [1606, 1900],
    [2039, 2400],
    [2283, 2700],
  ],
  miller10: [
    [47,   50],
    [176,  200],
    [426,  500],
    [767,  900],
    [1191, 1400],
    [1611, 1900],
    [2032, 2400],
    [2278, 2700],
  ],
};

function bookPageToPdfPage(bookPageStr, book) {
  const cal = PDF_CALIBRATION[book];
  if (!cal) return null;
  // Extract first number from strings like "עמוד 397" / "עמ׳ 294-5" / "עמ 424"
  const match = bookPageStr && bookPageStr.match(/(\d+)/);
  if (!match) return null;
  const bookPage = parseInt(match[1], 10);

  // Before first calibration point
  if (bookPage <= cal[0][0]) {
    return Math.round(bookPage + (cal[0][1] - cal[0][0]));
  }
  // After last calibration point — extrapolate using last two points
  if (bookPage >= cal[cal.length - 1][0]) {
    const last = cal[cal.length - 1];
    const prev = cal[cal.length - 2];
    const slope = (last[1] - prev[1]) / (last[0] - prev[0]);
    return Math.round(last[1] + (bookPage - last[0]) * slope);
  }
  // Linear interpolation between surrounding calibration points
  for (let i = 0; i < cal.length - 1; i++) {
    const [b0, p0] = cal[i];
    const [b1, p1] = cal[i + 1];
    if (bookPage >= b0 && bookPage <= b1) {
      const t = (bookPage - b0) / (b1 - b0);
      return Math.round(p0 + t * (p1 - p0));
    }
  }
  return null;
}

