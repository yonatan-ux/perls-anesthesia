// ── Helpers ───────────────────────────────────────────────────────
const uniq  = (arr, fn) => [...new Map(arr.map(x => [fn(x), x])).values()];
const tog   = (set, val) => { const s = new Set(set); s.has(val) ? s.delete(val) : s.add(val); return s; };
const bc    = p => p >= 80 ? "var(--teal)" : p >= 60 ? "var(--gold)" : "var(--red)";
const getChipPerf = (qs, perfMap) => {
  const tried = qs.filter(q => perfMap[q.id] !== undefined);
  if (tried.length === 0) return null;          // never attempted → neutral
  const correct = tried.filter(q => perfMap[q.id] === "correct").length;
  const pct = Math.round(correct / tried.length * 100);
  return pct >= 80 ? "pt-teal" : pct >= 60 ? "pt-gold" : "pt-red";
};

// ── Donut chart ───────────────────────────────────────────────────
function Donut({ segments, size = 96 }) {
  const cx = size / 2, cy = size / 2;
  const R = size * 0.46, r = size * 0.30;
  const total = segments.reduce((s, seg) => s + seg.value, 0);
  if (total === 0) return (
    <svg viewBox={`0 0 ${size} ${size}`} width={size} height={size}>
      <circle cx={cx} cy={cy} r={R} fill="none" stroke="#e4ddd0" strokeWidth={R - r} />
    </svg>
  );

  let angle = -Math.PI / 2;
  const paths = [];
  segments.forEach(seg => {
    if (seg.value === 0) return;
    const frac = seg.value / total;
    const sweep = frac * 2 * Math.PI;
    const end   = angle + sweep;
    const large = frac > 0.5 ? 1 : 0;
    // Handle full-circle edge case
    if (frac > 0.9999) {
      paths.push(
        <circle key={seg.label} cx={cx} cy={cy} r={(R+r)/2}
          fill="none" stroke={seg.color} strokeWidth={R-r} />
      );
    } else {
      const x1=cx+R*Math.cos(angle), y1=cy+R*Math.sin(angle);
      const x2=cx+R*Math.cos(end),   y2=cy+R*Math.sin(end);
      const x3=cx+r*Math.cos(end),   y3=cy+r*Math.sin(end);
      const x4=cx+r*Math.cos(angle), y4=cy+r*Math.sin(angle);
      const d=`M${x1} ${y1} A${R} ${R} 0 ${large} 1 ${x2} ${y2} L${x3} ${y3} A${r} ${r} 0 ${large} 0 ${x4} ${y4}Z`;
      paths.push(<path key={seg.label} d={d} fill={seg.color} />);
    }
    angle = end;
  });

  return (
    <svg viewBox={`0 0 ${size} ${size}`} width={size} height={size}>
      {paths}
    </svg>
  );
}

