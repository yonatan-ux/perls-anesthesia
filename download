  const [fNew,   setFNew]   = useState(false);
  const [fNotes, setFNotes] = useState(false);
  const [count,  setCount]  = useState(10);
  const [notes,  setNotes]  = useState({});
  const [topicQ, setTopicQ] = useState("");
  const [openSec, setOpenSec] = useState(new Set());
  const toggleSec = (k) => setOpenSec(p => tog(p, k));

  useEffect(() => { loadNotes().then(setNotes); }, []);

  // Refresh notes count when returning from a quiz session
  useEffect(() => {
    const handler = () => loadNotes().then(setNotes);
    window.addEventListener("focus", handler);
    return () => window.removeEventListener("focus", handler);
  }, []);

  // derive unique values present in bank
  const allSrcs   = useMemo(() => [...new Set(QUESTIONS.map(q => q.source))], []);
  const allTopics = useMemo(() => [...new Set(QUESTIONS.map(q => q.topic))].sort(), []);
  const allBooks  = useMemo(() => [...new Set(QUESTIONS.map(q => q.book))], []);

  // questions grouped by source and topic for perf coloring
  const qsBySrc   = useMemo(() => {
    const m = {};
    allSrcs.forEach(s => { m[s] = QUESTIONS.filter(q => q.source === s); });
    return m;
  }, [allSrcs]);
  const qsByTopic = useMemo(() => {
    const m = {};
    allTopics.forEach(t => { m[t] = QUESTIONS.filter(q => q.topic === t); });
    return m;
  }, [allTopics]);

  // last performance per question id
  const perfMap = useMemo(() => {
    const m = {};
    history.forEach(h => { m[h.id] = h.skipped ? "wrong" : h.correct ? "correct" : "wrong"; });
    return m;
  }, [history]);

  const filtered = useMemo(() => QUESTIONS.filter(q => {
    if (fSrc.size   && !fSrc.has(q.source))   return false;
    if (fTopic.size && !fTopic.has(q.topic))   return false;
    if (fBook.size  && !fBook.has(q.book))     return false;
    if (fFlag  && !flagged.has(q.id))          return false;
    if (fNotes && !notes[makeQid(q.source, q.id)]) return false;
    if (fNew   && perfMap[q.id] !== undefined) return false;
    if (fPerf.size) {
      const p = perfMap[q.id] ?? "unanswered";
      if (!fPerf.has(p)) return false;
    }
    return true;
  }), [fSrc, fTopic, fBook, fFlag, fNotes, fNew, fPerf, perfMap, flagged, notes]);

  const actual = count === "הכל" ? filtered.length : Math.min(count, filtered.length);
  const canStart = filtered.length > 0;

  const start = () => {
    const pool = [...filtered].sort(() => Math.random() - .5).slice(0, actual);
    onStart(pool);
  };

  const Section = ({ label, children }) => (
    <div className="sec">
      <div className="sec-lbl">{label}</div>
      {children}
    </div>
  );
  const AccSection = ({ id, label, badge, badgeWarn, children }) => {
    const isOpen = openSec.has(id);
    return (
      <div className="acc-sec">
        <div className="acc-hdr" onClick={() => toggleSec(id)}>
          <div className="acc-hdr-left">
            <span className="acc-lbl">{label}</span>
            {badge ? <span className={`acc-badge${badgeWarn?" acc-badge-warn":""}`}>{badge}</span> : null}
          </div>
          <span className={`acc-arrow${isOpen?" open":""}`}>▼</span>
        </div>
        {isOpen && <div className="acc-body">{children}</div>}
      </div>
    );
  };

  const Chip = ({ label, active, colorClass="on", perfTier, onClick }) => (
    <button className={`chip ${active ? colorClass : perfTier || ""}`} onClick={onClick}>{label}</button>
  );

  // ── stats derived from perfMap across ALL questions ──
  const nCorrect    = QUESTIONS.filter(q => perfMap[q.id] === "correct").length;
  const nWrong      = QUESTIONS.filter(q => perfMap[q.id] === "wrong").length;
  const nUnanswered = QUESTIONS.length - nCorrect - nWrong;
  const donutSegs   = [
    { label:"ידעתי",    value: nCorrect,    color:"#1a7a70" },
    { label:"נכשלתי",   value: nWrong,      color:"#b03020" },
    { label:"לא נסיתי", value: nUnanswered, color:"#e4ddd0" },
  ];

  const filteredTopics = useMemo(() =>
    allTopics.filter(t => !topicQ || t.includes(topicQ)), [allTopics, topicQ]);

  const nNew = QUESTIONS.filter(q => perfMap[q.id] === undefined).length;

  return (
    <div className="builder-shell fi">
      {/* ── Header ── */}
      <div className="hdr perl-hdr">
        <div className="perl-brand">
          <img src="data:image/png;base64," className="perl-logo" alt="Perl's Anesthesia logo"/>
          <div className="perl-name-block">
            <div className="perl-app-name">Perl's Anesthesia</div>
            <div className="perl-subtitle">לזכר ד"ר גיזלה פרל · Auschwitz 1907–1988</div>
          </div>
        </div>
        <div style={{display:"flex",flexDirection:"column",alignItems:"flex-end",gap:6}}>
          <button className="io-btn" onClick={onExport}>↓ גיבוי</button>
          <button className="io-btn" onClick={() => onImport(null)}>↑ שחזור</button>
        </div>
      </div>

      {importMsg && (
        <div className={`io-msg ${importMsg.ok ? "io-msg-ok" : "io-msg-err"}`}>
          {importMsg.ok ? "✓ " : "✗ "}{importMsg.text}
        </div>
      )}

      <div className="page-body">
      {/* ── Cockpit: stats + start ── */}
      <div className="builder-cockpit">
        <div className="cockpit-donut">
          <svg viewBox="0 0 80 80" width="80" height="80">
            {(() => {
              const total = nCorrect + nWrong + nUnanswered || 1;
              const segs = [{v:nCorrect,c:"#1a7a70"},{v:nWrong,c:"#b03020"},{v:nUnanswered,c:"rgba(255,255,255,.18)"}];
              let a = -Math.PI/2; const R=36,r=24,cx=40,cy=40;
              return segs.map((seg,i) => {
                if(!seg.v) return null;
                const frac=seg.v/total, sweep=frac*2*Math.PI, end=a+sweep;
                const large=frac>.9999;
                let path;
                if(large){
                  path=<circle key={i} cx={cx} cy={cy} r={(R+r)/2} fill="none" stroke={seg.c} strokeWidth={R-r}/>;
                } else {
                  const x1=cx+R*Math.cos(a),y1=cy+R*Math.sin(a),x2=cx+R*Math.cos(end),y2=cy+R*Math.sin(end);
                  const x3=cx+r*Math.cos(end),y3=cy+r*Math.sin(end),x4=cx+r*Math.cos(a),y4=cy+r*Math.sin(a);
                  path=<path key={i} d={`M${x1} ${y1} A${R} ${R} 0 ${frac>.5?1:0} 1 ${x2} ${y2} L${x3} ${y3} A${r} ${r} 0 ${frac>.5?1:0} 0 ${x4} ${y4}Z`} fill={seg.c}/>;
                }
                a=end; return path;
              });
            })()}
          </svg>
          <div className="cockpit-center">
            <div className="cockpit-num">{QUESTIONS.length}</div>
            <div className="cockpit-lbl">שאלות</div>
          </div>
        </div>
        <div className="cockpit-perf">
          {[
            {c:"#1a7a70",l:"ידעתי",    n:nCorrect,    perfId:"correct"},
            {c:"#b03020",l:"לא ידעתי", n:nWrong,      perfId:"wrong"},
            {c:"rgba(255,255,255,.4)",l:"לא ניסיתי",n:nUnanswered,perfId:"unanswered"},
          ].map(({c,l,n,perfId})=>{
            const active = fPerf.has(perfId);
            return (
              <div key={l} className={`cockpit-pf${active?" cpf-on":""}`}
                onClick={()=>{ setFNew(false); setFPerf(p=>tog(p,perfId)); }}>
                <div className="cockpit-dot" style={{background:c}}/>
                <span className="cockpit-row-lbl">{l}</span>
                <span className="cockpit-row-num">{n}</span>
                <span className="cockpit-row-pct">{QUESTIONS.length>0?Math.round(n/QUESTIONS.length*100):0}%</span>
              </div>
            );
          })}
        </div>
        <div className="cockpit-start">
          <button className="cockpit-btn" disabled={!canStart} onClick={start}>
            {canStart ? <>💉<br/>{actual} שאלות</> : "אין תואמות"}
          </button>
          <div className="cockpit-count">
            {COUNT_OPTS.map(n => (
              <button key={n} className={`cockpit-cc${count===n?" on":""}`}
                disabled={n!=="הכל" && filtered.length<n}
                onClick={() => setCount(n)}>{n}</button>
            ))}
          </div>
        </div>
      </div>

      {/* ── Quick filters row ── */}
      <div className="qf-row">
        {nNew > 0 && (
          <button className={`qf-btn${fNew?" qf-teal":""}`}
            onClick={() => { setFNew(v => !v); setFPerf(new Set()); }}>
            🆕 חדשות{nNew > 0 ? ` (${nNew})` : ""}
          </button>
        )}
        <button className={`qf-btn${fFlag?" qf-flag":""}`}
          onClick={() => setFFlag(v => !v)}>
          🚩 מסומנות{flagged.size > 0 ? ` (${flagged.size})` : ""}
        </button>
        <button className={`qf-btn${fNotes?" qf-gold":""}`}
          onClick={() => setFNotes(v => !v)}>
          📝 הערות{Object.keys(notes).length > 0 ? ` (${Object.keys(notes).length})` : ""}
        </button>
      </div>

      {/* ── Filters (accordion) ── */}
      <AccSection id="src" label="מקור המבחן" badge={fSrc.size||null}>
        <div className="chips">
          {allSrcs.map(s => (
            <Chip key={s} label={s} active={fSrc.has(s)}
              perfTier={getChipPerf(qsBySrc[s]||[], perfMap)}
              onClick={() => setFSrc(p => tog(p, s))} />
          ))}
        </div>
      </AccSection>

      <AccSection id="topic" label="נושא / פרק"
        badge={fTopic.size ? fTopic.size : null}>
        <input className="topic-search" placeholder="חיפוש פרק…" value={topicQ}
          onChange={e => setTopicQ(e.target.value)} />
        <div className="chips">
          {filteredTopics.map(t => (
            <Chip key={t} label={t} active={fTopic.has(t)}
              perfTier={getChipPerf(qsByTopic[t]||[], perfMap)}
              onClick={() => setFTopic(p => tog(p, t))} />
          ))}
        </div>
      </AccSection>

      <AccSection id="book" label="ספר מקור" badge={fBook.size||null}>
        <div className="chips">
          {allBooks.map(b => (
            <Chip key={b} label={BOOK_LABELS[b]||b} active={fBook.has(b)}
              colorClass="on-gold" onClick={() => setFBook(p => tog(p, b))} />
          ))}
        </div>
      </AccSection>



      {/* ── Match info ── */}
      <div style={{textAlign:"center",padding:"12px 0",color:"var(--soft)",fontSize:".82rem",fontFamily:"'Space Mono',monospace"}}>
        {filtered.length} שאלות תואמות · יוצגו {actual}
        {filtered.filter(q=>notes[makeQid(q.source,q.id)]).length>0 &&
          <span style={{color:"var(--gold)",marginRight:6}}>· {filtered.filter(q=>notes[makeQid(q.source,q.id)]).length} 📝</span>}
      </div>
      </div>{/* /page-body */}
      <div className="bottom-disclaimer">פרל היא כלי עזר ואינה נועדה לשימוש קליני.</div>
      <BottomNav active="train" onNav={onNav}/>
    </div>
  );
}

// ── Quiz screen ───────────────────────────────────────────────────
function Quiz({ questions, flagged, setFlagged, onDone }) {
  const [qi,     setQi]     = useState(0);
  const [sel,    setSel]    = useState(null);
  const [rev,    setRev]    = useState(false);
  const [hist,   setHist]   = useState([]);
  const [struck, setStruck] = useState(new Set());
  const [expTxt, setExpTxt] = useState("");
  const [expLd,  setExpLd]  = useState(false);
  const [expErr, setExpErr] = useState(null);
  const [note,   setNote]   = useState("");
  const [noteOpen, setNoteOpen] = useState(false);
  const [noteSaved, setNoteSaved] = useState(false);

  const q      = questions[qi];
  const isLast = qi + 1 >= questions.length;

  const loadExp = useCallback(async () => {
    const cached = EXP_CACHE[q.id];
    if (cached) {
      // Support both old string format and new structured object format
      setExpTxt(typeof cached === "object" ? cached : { _raw: cached });
      return;
    }
    setExpLd(true); setExpTxt(null); setExpErr(null);
    try { await streamExplanation(q, c => setExpTxt(p => p ? (typeof p === "object" && p._stream ? {...p, _stream: p._stream + c} : {_stream: c}) : {_stream: c})); }
    catch (e) { setExpErr(e.message); }
    finally { setExpLd(false); }
  }, [q]);

  // Load existing note when question changes
  const qid = makeQid(q.source, q.id);
  useEffect(() => {
    loadNotes().then(notes => {
      const existing = notes[qid] || "";
      setNote(existing);
      setNoteOpen(!!existing);
      setNoteSaved(false);
    });
  }, [qid]);

  const pick = i => {
    if (rev) return;
    setSel(i); setRev(true);
    setHist(h => [...h, { id:q.id, correct:q.ans.includes(i), skipped:false, topic:q.topic }]);
    loadExp();
  };
  const skip = () => {
    setRev(true); setSel(null);
    setHist(h => [...h, { id:q.id, correct:null, skipped:true, topic:q.topic }]);
    loadExp();
  };
  const toggleStrike = (i, e) => {
    e.stopPropagation();
    setStruck(p => tog(p, i));
  };
  const toggleFlag = () => setFlagged(p => tog(p, q.id));
  const next = () => {
    if (isLast) { onDone(hist); return; }
    setQi(n=>n+1); setSel(null); setRev(false); setStruck(new Set());
    setExpTxt(""); setExpErr(null); setExpLd(false);
    setNote(""); setNoteOpen(false); setNoteSaved(false);
  };

  const lastH    = hist[hist.length - 1];
  const isFlagged = flagged.has(q.id);

  return (
    <div className="page fi">
      <div className="hdr">
        <div>
          <div className="hdr-lbl">{q.source}</div>
          <div className="hdr-title">{q.topic}</div>
        </div>
        <div className="hdr-r">
          <div className="qnum">{String(qi+1).padStart(2,"0")}</div>
          <div className="qof">/ {questions.length}</div>
        </div>
      </div>

      <div className="pbar"><div className="pfill" style={{width:`${(qi/questions.length)*100}%`}}/></div>

      <div className="qcard">
        <div className="qmeta">
          <span className="badge bt">{q.topic}</span>
          <span className="badge bs">{q.source}</span>
          <span className="badge bm">{BOOK_LABELS[q.book]||q.book} · {q.pageRef}{(() => {
            const pdfPg = bookPageToPdfPage(q.pageRef, q.book);
            return pdfPg ? <span className="pdf-page-badge"> (PDF {pdfPg})</span> : null;
          })()}</span>
          <span className="badge" style={{background:"var(--p3)",color:"var(--faint)",border:"1px solid var(--rule)",fontFamily:"'Space Mono',monospace",letterSpacing:".04em"}}>
            {qid}
          </span>
        </div>
        <div className="qtext">{q.q}</div>

      </div>

      {!rev && <div className="hint">לחץ על ━ למחיקת תשובה · לחץ על התשובה לבחירה</div>}

      <div className="opts">
        {q.opts.map((opt, i) => {
          let cls = "opt";
          if (!rev && struck.has(i)) cls += " struck";
          if (rev) { if (q.ans.includes(i)) cls += " ok"; else if (i===sel) cls += " no"; else cls += " dim"; }
          return (
            <div key={i} className="opt-wrap">
              <button className={cls} disabled={rev} onClick={() => pick(i)}>
                <span className="oletter">{HEB[i]}</span>
                <span className="opttext">{opt}</span>
              </button>
              {!rev && (
                <button className={`strike-btn ${struck.has(i)?"on":""}`}
                  onClick={e => toggleStrike(i,e)}>━</button>
              )}
            </div>
          );
        })}
      </div>

      {!rev && (
        <button className="skip-btn" onClick={skip}>
          {q.hasImage ? "↷ דלג — שאלה עם איור שאינו ברור" : "↷ דלג על שאלה זו"}
        </button>
      )}

      {rev && (
        <div className="fi">
          {lastH?.skipped
            ? <div className="verdict vsk">↷ דולג · תשובה נכונה: {HEB[q.ans[0]]}. {q.opts[q.ans[0]]}</div>
            : lastH?.correct
              ? <div className="verdict vok">✓ תשובה נכונה</div>
              : <div className="verdict vno">✗ שגוי · הנכונה: {HEB[q.ans[0]]}. {q.opts[q.ans[0]]}</div>}

          <div className="exp">
            <div className="exph">
              <span>הסבר לפי {BOOK_LABELS[q.book]||q.book}</span>
              <span className="expp">{q.pageRef}{(() => {
                const pdfPg = bookPageToPdfPage(q.pageRef, q.book);
                if (!pdfPg) return null;
                return (
                  <span className="pdf-page-badge" title={`עמוד ${pdfPg} בקובץ ה-PDF`}>
                    {" "}· PDF עמ׳ {pdfPg}
                  </span>
                );
              })()}</span>
            </div>
            {expLd && !expTxt && <div className="expload"><span className="dots"><span/><span/><span/></span>טוען הסבר…</div>}
            {expErr && <div className="experr"><span>שגיאה: {expErr}</span><button className="retry-btn" onClick={loadExp}>↺ נסה שוב</button></div>}
            {expTxt && (() => {
              // Structured cache object
              if (typeof expTxt === "object" && !expTxt._raw && !expTxt._stream) {
                const e = expTxt;
                return (
                  <div className="exp-structured">
                    {/* Main explanation */}
                    <div className="exptxt">{e.explanation}</div>

                    {/* Figure */}
                    {e.figure && (
                      <div className="exp-figure">
                        <img src={e.figure.src} alt={e.figure.caption} className="exp-fig-img"/>
                        <div className="exp-fig-caption">{e.figure.caption}</div>
                      </div>
                    )}

                    {/* Wrong answers section */}
                    {e.distractors && (
                      <div className="dist-section">
                        <div className="dist-title">מדוע שאר האפשרויות שגויות</div>
                        {Object.entries(e.distractors).map(([letter, text]) => (
                          <div key={letter} className="dist-item">
                            <span className="dist-letter">{letter}</span>
                            <span className="dist-text">{text}</span>
                          </div>
                        ))}
                      </div>
                    )}

                    {/* Book citations */}
                    {e.quotes && e.quotes.length > 0 && (
                      <div className="quotes-section">
                        <div className="quotes-title">ראיות מספר הלימוד</div>
                        {e.quotes.map((qt, i) => (
                          <div key={i} className="quote-card">
                            <div className="quote-text">"{qt.text}"</div>
                            <div className="quote-source">{qt.chapter} — {qt.page}</div>
                          </div>
                        ))}
                      </div>
                    )}

                    {/* הגב button */}
                    <button className="hagev-btn" onClick={() => {
                      const qid = makeQid(q.source, q.id);
                      const subject = encodeURIComponent(`[הגב] ${qid} — ${q.q.slice(0,60)}`);
                      const body = encodeURIComponent(`שאלה: ${qid}\nמקור: ${q.source}\nעמ׳: ${q.pageRef}\n\nהצעה לתיקון:\n`);
                      window.open(`mailto:feedback@perls-anesthesia.com?subject=${subject}&body=${body}`);
                    }}>
                      ✏️ הגב / הצע תיקון
                    </button>
                  </div>
                );
              }
              // Legacy string or stream
              const txt = expTxt._raw || expTxt._stream || expTxt;
              return <div className="exptxt">{txt}</div>;
            })()}

            {/* Personal note */}
            {(expTxt || expErr) && (
              <div className="note-box">
                <button className="note-toggle" onClick={() => setNoteOpen(v => !v)}>
                  {note ? <span className="note-dot"/> : <span style={{fontSize:".9rem"}}>📝</span>}
                  {note ? "הערה אישית" : noteOpen ? "סגור" : "+ הוסף הערה אישית"}
                </button>
                {noteOpen && (
                  <div className="fi">
                    <textarea
                      className="note-ta"
                      placeholder="כתוב כאן פנינת זיכרון, הערה קלינית, או קיצור דרך לזכור…"
                      value={note}
                      onChange={e => { setNote(e.target.value); setNoteSaved(false); }}
                      onBlur={async () => {
                        await saveNote(qid, note);
                        setNoteSaved(true);
                        setTimeout(() => setNoteSaved(false), 2000);
                      }}
                    />
                    <div className="note-saved" style={{opacity: noteSaved ? 1 : 0}}>
                      ✓ נשמר
                    </div>
                  </div>
                )}
              </div>
            )}
          </div>

          <div className="action-row">
            <button className="btn-p" onClick={next}>{isLast?"סיום וצפייה בתוצאות ←":"שאלה הבאה ←"}</button>
            <button className={`flag-btn ${isFlagged?"on":""}`} onClick={toggleFlag}
              title={isFlagged?"הסר סימון":"סמן לחזרה"}>🚩</button>
          </div>
        </div>
      )}
    </div>
  );
}

// ── Results screen ────────────────────────────────────────────────
function Results({ hist, flagged, onBack }) {
  const nc  = hist.filter(h => h.correct === true).length;
  const ns  = hist.filter(h => h.skipped).length;
  const pct = hist.length > 0 ? Math.round((nc / hist.length) * 100) : 0;

  const topicMap = {};
  hist.forEach(h => {
    const t = h.topic || "כללי";
    if (!topicMap[t]) topicMap[t] = { correct:0, total:0 };
    topicMap[t].total++;
    if (h.correct === true) topicMap[t].correct++;
  });
  const topics = Object.entries(topicMap).sort(([,a],[,b]) => (a.correct/a.total)-(b.correct/b.total));

  const wrongItems   = hist.filter(h => h.correct === false || h.skipped);
  const flaggedItems = hist.filter(h => flagged.has(h.id) && h.correct === true && !h.skipped);

  return (
    <div className="page fi">
      <div className="hdr-lbl" style={{marginBottom:4}}>תוצאות</div>
      <div className="res-rule"/>
      <div style={{textAlign:"center",marginBottom:28}}>
        <div className="res-lbl">ציון</div>
        <div className="res-pct">{pct}%</div>
        <div className="res-sub">
          {nc} מתוך {hist.length} נכונות
          {ns>0 ? ` · ${ns} דולגו (נספרו כשגויות)` : ""}
          {flagged.size>0 ? ` · ${flagged.size} מסומנות לחזרה` : ""}
        </div>
      </div>

      {topics.length > 0 && <>
        <div className="r-sec">ביצועים לפי נושא</div>
        <div className="topic-rows">
          {topics.map(([t,s]) => {
            const p = Math.round((s.correct/s.total)*100);
            return (
              <div key={t} className="topic-row">
                <div className="topic-hdr">
                  <span className="topic-name">{t}</span>
                  <span className="topic-pct">{s.correct}/{s.total} · {p}%</span>
                </div>
                <div className="tbar"><div className="tbar-fill" style={{width:`${p}%`,background:bc(p)}}/></div>
              </div>
            );
          })}
        </div>
      </>}

      {(wrongItems.length>0 || flaggedItems.length>0) && <>
        <div className="r-sec">לחזרה</div>
        <div className="rev-list">
          {wrongItems.map(h => {
            const qd = QUESTIONS.find(x=>x.id===h.id);
            return (
              <div key={h.id} className="rev-item rev-wrong">
                <div className="rev-lbl rev-lbl-w">{h.skipped?"↷ דולג":"✗ שגוי"}</div>
                <div>{qd?.q.slice(0,80)}{qd?.q.length>80?"…":""}</div>
