// ── Stats Screen ─────────────────────────────────────────────────
function StatsScreen({ history }) {
  const total   = history.length;
  const correct = history.filter(h=>h.correct).length;
  const pct     = total ? Math.round(correct/total*100) : 0;
  const streak  = useMemo(() => {
    let s=0, d=today();
    while(true){ const c=history.filter(h=>(h.date||"").startsWith(d)).length; if(!c) break; s++; d=addDays(d,-1); }
    return s;
  }, [history]);
  const sessions = useMemo(()=>{
    return new Set(history.map(h=>(h.date||"").slice(0,10))).size;
  }, [history]);

  const byTopic = useMemo(() => {
    const m = {};
    history.forEach(h => {
      const q = QUESTIONS.find(q=>q.id===h.id);
      if (!q) return;
      if (!m[q.topic]) m[q.topic] = {c:0,t:0};
      m[q.topic].t++;
      if (h.correct) m[q.topic].c++;
    });
    return Object.entries(m)
      .map(([t,v])=>([t,Math.round(v.c/v.t*100),v.t]))
      .sort((a,b)=>a[1]-b[1]);
  }, [history]);

  const METRICS = [
    { label:"שאלות נענו",          value: total > 0 ? total : null,              ph:"יוצג לאחר תרגול ראשון" },
    { label:"אחוז הצלחה",         value: total > 0 ? `${pct}%` : null,          ph:"יוצג לאחר תרגול ראשון" },
    { label:"רצף ימים",           value: streak > 0 ? `${streak}` : null,       ph:"יוצג לאחר יום תרגול" },
    { label:"ימי לימוד",          value: sessions > 0 ? `${sessions}` : null,   ph:"יוצג לאחר תרגול" },
    { label:"זמן ממוצע לשאלה",    value: null,                                   ph:"בפיתוח" },
    { label:"שיפור לאורך זמן",    value: null,                                   ph:"בפיתוח" },
    { label:"Spaced Repetition",  value: null,                                   ph:"בפיתוח" },
    { label:"נושאים לחיזוק",      value: byTopic.length > 0 ? `${byTopic.length} פרקים` : null, ph:"יוצג לאחר 3 שאלות בפרק" },
  ];

  return (
    <div className="page stats-page">
      <div className="hdr"><div className="hdr-lbl">ביצועים</div><div className="hdr-title">התקדמות</div></div>

      {total === 0 ? (
